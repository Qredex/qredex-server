{
  "name": "@qredex/node",
  "version": "0.1.0",
  "description": "Canonical Node.js server SDK for the Qredex Integrations API.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Qredex/qredex-node.git"
  },
  "homepage": "https://github.com/Qredex/qredex-node#readme",
  "bugs": {
    "url": "https://github.com/Qredex/qredex-node/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "CHANGELOG.md",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage",
    "release:check": "npm run typecheck && npm test && npm run build",
    "test": "vitest run",
    "test:live": "vitest run tests/live.integration.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run release:check"
  },
  "keywords": [
    "qredex",
    "sdk",
    "typescript",
    "node",
    "integrations",
    "attribution"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.4"
  }
}
